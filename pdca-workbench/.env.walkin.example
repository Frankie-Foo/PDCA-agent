# 门店五件套录入（/walkin-submit）独立部署 · 生产环境敏感配置模板
# 复制为未跟踪的 .env.walkin，禁止提交到仓库。

# JWT 签名密钥，至少 32 位随机字符串，且必须与主服务（pdca-workbench 容器）的
# PDCA_SECRET_KEY 不同——两边容器完全独立，密钥不共用，dealer token 和内部工作台
# token 互不通用，域名/cookie 也不同，这样更干净。
# 生成方式（任选）：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   openssl rand -base64 32
PDCA_WALKIN_SECRET_KEY=

# 与主服务共用同一个生产 Postgres 库即可，已有 users/dealer_stores/walkin_daily_reports
# 表和经销商账号，不需要建新库或迁移数据。
# 格式：postgresql+psycopg2://用户名:密码@主机:端口/数据库名
PDCA_DATABASE_URL=postgresql+psycopg2://pdca:your_password@10.100.0.176:5432/pdca
