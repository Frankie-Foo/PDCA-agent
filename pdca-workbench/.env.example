# PDCA 工作台生产环境配置

# 服务
PDCA_ENV=production
TZ=Asia/Shanghai
PDCA_WORKBENCH_PORT=8767
PDCA_HOST_PORT=8768
PDCA_HOST=0.0.0.0
PDCA_SECRET_KEY=

# PostgreSQL（必填，由你方建库后填入）
# 格式：postgresql+psycopg2://用户名:密码@主机:端口/数据库名
PDCA_DATABASE_URL=postgresql+psycopg2://pdca:your_password@localhost:5432/pdca

# 仅首次建库时可临时设置；创建后立即从 .env 删除
# PDCA_BOOTSTRAP_ADMIN_USERNAME=admin
# PDCA_BOOTSTRAP_ADMIN_PASSWORD=请使用至少12位随机密码
# PDCA_BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员

# 业务数据路径
PDCA_MVP_ROOT=D:/经销商PDCA/data_platform/data_role_pdca_mvp
PDCA_REPO_ROOT=D:/经销商PDCA

# vertu-cli 2.x
VERTU_COMMAND=vertu-cli
VERTU_VPS_SERVICE_URL=https://vps-service.vertu.cn
VERTU_APP_ID=cursor
# 使用 `vertu-cli agent env --app-id cursor --shell powershell` 读取；仅放在服务器密钥环境或未跟踪的 .env。
VERTU_APP_KEY=
VERTU_USER_LOGIN=
# Optional: production can use this Bot Key or a persisted `vertu login` user session.
VERTU_BOT_INBOUND_KEY=
VERTU_LEGACY_COMMAND=vertu
PDCA_REQUIRE_VERTU=1
PDCA_INCLUDE_DEMO_DATA=0
PDCA_MAX_REPORTED_REVENUE_USD=5000000
PDCA_REVENUE_REVIEW_THRESHOLD_USD=1000000

# 定时任务
PDCA_SCHEDULER_ENABLED=1
PDCA_SYNC_CRON=0 6 * * *
PDCA_LOG_LEVEL=INFO

# HTTPS（NGINX 负责 SSL 终止时设 1，Cookie 会携带 Secure 标志）
# 对外上线必须设为 1，否则浏览器拒绝 httpOnly Cookie
PDCA_SECURE_COOKIES=1
PDCA_SSL_CERT=./certs/cert.pem
PDCA_SSL_KEY=./certs/key.pem

# 认证模式：对外经销商必须用 local（不依赖内网 vertu 命令）
# local=本地账号 | vps=仅 vertu/Odoo 登录 | hybrid=本地 JWT + VPS 均可
PDCA_AUTH_MODE=hybrid
# VPS 未登录时登录页跳转链接（auth_mode=vps 时使用）
PDCA_VPS_LOGIN_URL=https://vps.vertu.cn
# 信任 Nginx/SSO 注入的 X-VPS-User-Login 等 Header（多用户生产设 1）
PDCA_TRUST_PROXY_HEADERS=0
# 每次 VPS 同步是否覆盖本地 role（默认 0，保留手工调权）
PDCA_VPS_SYNC_ROLE=0
# CORS 白名单，逗号分隔；留空则 * 且关闭 credentials
# PDCA_CORS_ORIGINS=https://pdca-workbench-teams.vertu.cn

# PostgreSQL 备份（pg_dump 用，可选；未设则从 PDCA_DATABASE_URL 解析）
# PDCA_PG_HOST=localhost
# PDCA_PG_PORT=5432
# PDCA_PG_USER=pdca
# PDCA_PG_PASSWORD=your_password
# PDCA_PG_DATABASE=pdca
# 可选：指定与服务器版本兼容的 pg_dump
# PDCA_PG_DUMP_COMMAND=/usr/lib/postgresql/18/bin/pg_dump
