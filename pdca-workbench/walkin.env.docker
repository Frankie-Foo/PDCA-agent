# 门店五件套录入（/walkin-submit）独立部署 · Docker 非敏感默认配置
# 密钥和数据库连接必须由未跟踪的 .env.walkin 或部署环境提供。
#
# 与 env.docker（内部工作台）的关键差异：
# - PDCA_AUTH_MODE=local（经销商账号不需要 VPS/vertu-cli SSO，.env.example 里本就建议
#   对外部署用 local）
# - PDCA_CORS_ORIGINS 指向对外域名，不是 -teams 内部域名
# - PDCA_REQUIRE_VERTU=0（这个容器不强依赖 vertu-cli 才能启动/health 健康）
# - PDCA_SCHEDULER_ENABLED=0（定时同步任务只需要内部工作台容器跑一份，避免两个容器各跑一遍）
PDCA_ENV=production
PDCA_HOST=0.0.0.0
PDCA_WORKBENCH_PORT=8767
PDCA_WALKIN_HOST_PORT=8769
PDCA_TOKEN_EXPIRE_MINUTES=480
PDCA_AUTH_MODE=local
PDCA_SECURE_COOKIES=1
PDCA_TRUST_PROXY_HEADERS=0
PDCA_REQUIRE_VERTU=0
PDCA_INCLUDE_DEMO_DATA=0
PDCA_MAX_REPORTED_REVENUE_USD=5000000
PDCA_CORS_ORIGINS=https://pdca-workbench.vertu.cn
PDCA_SCHEDULER_ENABLED=0
PDCA_LOG_LEVEL=INFO
PDCA_WORKERS=1
